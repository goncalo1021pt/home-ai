# Copy to .env and fill in. .env is gitignored.

# === Required ===

# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=


# === Optional ===

# Personality. Defaults to "friday". Options: friday | jarvis (jarvis is a stub).
# PERSONALITY=friday

# Input mode. Defaults to "text". Options: text | voice
# Voice mode requires faster-whisper (already in requirements.txt) and a
# working microphone (on WSL2, install libportaudio2 + alsa/pulseaudio
# packages — see PR #2 description).
# INPUT_MODE=voice

# Whisper model size (voice mode only). Default: medium. Options:
#   tiny, base, small, medium, large-v2, large-v3, large-v3-turbo
# .en variants are English-only and faster — but our default supports
# multilingual (PT/EN) so we use the plain (non-.en) versions.
# WHISPER_MODEL=medium

# Whisper device. Default: auto (CUDA if available, else CPU).
# Options: auto | cuda | cpu
# WHISPER_DEVICE=auto

# Whisper language hint. Empty = auto-detect per utterance (works well
# for PT/EN). Set to "pt" or "en" to lock it.
# WHISPER_LANGUAGE=
